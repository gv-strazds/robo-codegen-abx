<?xml version="1.0"?>
<!-- -->
<robot name="madara_pad">
    <link name="world"/>
    <link name="madara_pad_link">
        <inertial>
            <mass value="0.01" />
            <origin xyz="0.000 0 0" rpy="0 0 0" />
            <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="madara_pad.stl"/>
            </geometry>
        </visual>
          <collision>
            <origin xyz="0.00 0 0" rpy="0 -0 0" />
            <geometry>
                <mesh filename="madara_pad.stl"/>
            </geometry>
        </collision> 
    </link>
    <joint name="madara_pad_joint" type="fixed">
        <origin xyz="0 0.0 0.0" rpy="0 0 0" />
        <parent link="world" />
        <child link="madara_pad_link" />
    </joint>
</robot>

